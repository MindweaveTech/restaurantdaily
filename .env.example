# ===========================================
# Restaurant Daily Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# For production, set these in Vercel/GitHub environment variables

PORT=3002

# ===========================================
# Supabase Configuration
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
DATABASE_URL=postgresql://user:password@host:5432/database

# ===========================================
# Authentication
# ===========================================
JWT_SECRET=your_super_secret_jwt_token_at_least_32_characters

# ===========================================
# Twilio SMS/WhatsApp Configuration
# ===========================================
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+14155238886
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ===========================================
# OTP Configuration (optional, defaults shown)
# ===========================================
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_PER_HOUR=3

# ===========================================
# Test Phone Numbers (Playwright E2E Testing)
# ===========================================
TEST_ORG_ADMIN_PHONE=+918826175074
TEST_OTP_RECEIVER_PHONE=+918826175074
